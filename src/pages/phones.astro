---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PhoneCard from "../components/PhoneCard.astro";
import { siteData } from "../data/siteData";
import { withBase } from "../utils/basePath";

const appBase = process.env.ASTRO_BASE;
const withBasePath = (path: string) => withBase(path, appBase);

const sheetValue =
  import.meta.env.PUBLIC_GOOGLE_SHEETS_DOCUMENT_ID ??
  import.meta.env.PUBLIC_GOOGLE_SHEETS_CSV_URL ??
  "";

const hasSheetConfig = Boolean(String(sheetValue).trim());

let phones: { model: string; price: string; storage: string; condition: string; image: string }[] = [];
let loadError = "";

if (hasSheetConfig) {
  try {
    const entries = await getCollection("phones");
    phones = entries
      .map(({ data }: any) => ({
        model: data.model,
        price: data.price,
        storage: data.storage,
        condition: data.condition,
        image: data.image,
      }))
      .filter((phone: any) => phone.model.length > 0 && phone.model.toLowerCase() !== "model");
  } catch (error) {
    loadError = "We could not load the latest inventory right now. Please call for availability.";
    console.error(error);
  }
} else {
  loadError =
    "Inventory feed is not configured yet. Set PUBLIC_GOOGLE_SHEETS_DOCUMENT_ID (or a Google Sheets URL in PUBLIC_GOOGLE_SHEETS_CSV_URL).";
}
---

<Layout
  title={`Used Phones in Ottawa | ${siteData.name}`}
  description="Browse available used phones in Ottawa with storage, condition, and pricing from our live inventory feed."
>
  <section class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Available Phones</h1>
        <p class="text-xl text-gray-300">
          Updated inventory from our Ottawa shop. Call us to reserve a device.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {loadError && (
        <div class="mb-8 bg-orange-500/10 border border-orange-500/30 rounded-xl p-4 text-orange-100">
          {loadError}
        </div>
      )}

      {phones.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {phones.map((phone) => (
            <PhoneCard
              model={phone.model}
              price={phone.price}
              storage={phone.storage}
              condition={phone.condition}
              image={phone.image}
            />
          ))}
        </div>
      ) : (
        <div class="bg-slate-900 rounded-xl border border-slate-700 p-10 text-center">
          <h2 class="text-3xl font-bold text-white mb-3">No Phones Listed Right Now</h2>
          <p class="text-gray-300 mb-6">
            Contact us for the latest arrivals and same-day availability.
          </p>
          <a
            href={withBasePath('/contact')}
            class="inline-flex items-center justify-center gap-3 bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-all"
          >
            Contact the Shop
            <i class="ri-arrow-right-line"></i>
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>
